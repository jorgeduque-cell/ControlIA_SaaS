generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model vendedores {
  id                BigInt          @id
  nombre_negocio    String          @default("Mi Negocio")
  estado            String          @default("Inactivo")
  fecha_vencimiento DateTime?       @db.Date
  telefono_soporte  String?
  fecha_registro    DateTime?       @default(now()) @db.Timestamp(6)
  logo_base64       String?
  meta_mensual      Float?          @default(0)
  clientes          clientes[]
  context_memory    context_memory[]
  finanzas          finanzas[]
  inventario        inventario[]
  metas             metas[]
  notas_cliente     notas_cliente[]
  pedidos           pedidos[]
  productos         productos[]
}

model clientes {
  id                 Int             @id @default(autoincrement())
  vendedor_id        BigInt
  nombre             String
  telefono           String?
  direccion          String?
  tipo_negocio       String?
  estado             String?         @default("Prospecto")
  fecha_registro     DateTime?       @db.Date
  ultima_interaccion DateTime?       @db.Date
  latitud            Float?
  longitud           Float?
  dia_visita         String?
  vendedores         vendedores      @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)
  notas_cliente      notas_cliente[]
  pedidos            pedidos[]
  context_memory     context_memory[]

  @@index([vendedor_id])
}

model productos {
  id                   Int        @id @default(autoincrement())
  vendedor_id          BigInt
  nombre               String
  precio_compra        Float?     @default(0)
  precio_venta         Float?     @default(0)
  stock_actual         Int?       @default(0)
  fecha_creacion       DateTime?  @default(dbgenerated("CURRENT_DATE")) @db.Date
  stock_minimo         Int?       @default(0)
  ultima_actualizacion DateTime?  @db.Date
  vendedores           vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([vendedor_id])
}

model inventario {
  id                   Int        @id @default(autoincrement())
  vendedor_id          BigInt
  producto             String
  stock_actual         Int        @default(0)
  stock_minimo         Int        @default(0)
  ultima_actualizacion DateTime?  @db.Date
  vendedores           vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([vendedor_id])
}

model pedidos {
  id            Int        @id @default(autoincrement())
  vendedor_id   BigInt
  cliente_id    Int?
  producto      String
  cantidad      Int
  precio_compra Float?
  precio_venta  Float?
  estado        String?    @default("Pendiente")
  estado_pago   String?    @default("Pendiente")
  fecha         DateTime?  @db.Date
  grupo_pedido  String?
  clientes      clientes?  @relation(fields: [cliente_id], references: [id])
  vendedores    vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)
  finanzas      finanzas[]

  @@index([vendedor_id])
  @@index([cliente_id])
}

model finanzas {
  id          Int        @id @default(autoincrement())
  vendedor_id BigInt
  tipo        String
  concepto    String?
  monto       Float
  fecha       DateTime?  @db.Date
  pedido_id   Int?
  pedidos     pedidos?   @relation(fields: [pedido_id], references: [id])
  vendedores  vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([vendedor_id])
}

model notas_cliente {
  id         Int        @id @default(autoincrement())
  vendedor_id BigInt
  cliente_id  Int
  texto       String
  fecha       DateTime?  @db.Date
  clientes    clientes   @relation(fields: [cliente_id], references: [id])
  vendedores  vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([vendedor_id])
}

model metas {
  id             Int        @id @default(autoincrement())
  vendedor_id    BigInt
  producto       String
  meta_unidades  Int        @default(0)
  mes            String
  fecha_creacion DateTime?  @db.Date
  vendedores     vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([vendedor_id])
}

model context_memory {
  id          BigInt    @id @default(autoincrement())
  vendedor_id BigInt
  cliente_id  Int?
  tipo        String    @db.VarChar(50)
  contenido   String    @db.Text
  metadata    Json?     @default("{}")
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  clientes    clientes? @relation(fields: [cliente_id], references: [id])
  vendedores  vendedores @relation(fields: [vendedor_id], references: [id], onDelete: Cascade)

  @@index([vendedor_id])
  @@index([cliente_id])
  @@index([tipo])
}

model baseClientes {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamp(6)
}
